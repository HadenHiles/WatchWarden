# ─── Watch Warden — Environment Variables ────────────────────────────────────
# All values are optional — the app runs out of the box with safe defaults.
# Set these to harden your deployment.
# NEVER commit .env to version control.
#
# Integration credentials (Plex, Tautulli, Jellyseerr, TMDB, Trakt) are
# configured through the onboarding wizard and stored in the database.
# You do NOT need to set them here.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
# Defaults to "watchwarden" if not set.
POSTGRES_PASSWORD=changeme_strong_password_here

# ─── Session / Auth ───────────────────────────────────────────────────────────
# Defaults are used if not set — a warning is logged in production.
# SESSION_SECRET and API_SECRET must match across api + web containers.
SESSION_SECRET=replace_me_with_a_32_char_secret_value!!
API_SECRET=replace_me_with_a_16_char_secret!!

# ─── Public URL ───────────────────────────────────────────────────────────────
# Set to your NAS/server address so browser-side API calls work correctly.
# Defaults to http://localhost:4000
NEXT_PUBLIC_API_URL=http://<your-nas-ip>:4000

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
