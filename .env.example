# ─── Watch Warden — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by api and worker services.
POSTGRES_PASSWORD=changeme_strong_password_here
DATABASE_URL=postgresql://watchwarden:changeme_strong_password_here@localhost:5432/watchwarden

# ─── Admin Credentials ────────────────────────────────────────────────────────
# Username for the single admin account.
ADMIN_USERNAME=admin

# bcrypt hash of the admin password.
# Generate with: node -e "const b=require('bcryptjs');console.log(b.hashSync('yourpassword',12))"
ADMIN_PASSWORD_HASH=$2a$12$placeholder_replace_with_real_hash

# ─── Session / Auth ───────────────────────────────────────────────────────────
# Minimum 32 characters.  Used to sign sessions in the API and Next.js web app.
SESSION_SECRET=replace_me_with_a_32_char_secret_value
API_SECRET=replace_me_with_a_different_api_secret

# Next.js NextAuth / iron-session
NEXTAUTH_SECRET=replace_me_with_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# ─── Tautulli ─────────────────────────────────────────────────────────────────
TAUTULLI_BASE_URL=http://your-tautulli-host:8181
TAUTULLI_API_KEY=your_tautulli_api_key_here

# ─── Jellyseerr ───────────────────────────────────────────────────────────────
JELLYSEERR_BASE_URL=http://your-jellyseerr-host:5055
JELLYSEERR_API_KEY=your_jellyseerr_api_key_here

# Jellyseerr user ID for the automation bot account (e.g. famflix-trending-bot).
# Create a dedicated user in Jellyseerr and put its numeric user ID here.
JELLYSEERR_BOT_USER_ID=2

# ─── External Trend Sources ───────────────────────────────────────────────────
# TMDB API key (free at https://developer.themoviedb.org)
TMDB_API_KEY=your_tmdb_api_key_here

# Trakt.tv API client ID (free at https://trakt.tv/oauth/applications)
TRAKT_CLIENT_ID=your_trakt_client_id_here

# ─── Web App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Watch Warden

# URL the Next.js server uses to reach the API (internal Docker network — never exposed to browser)
API_URL=http://localhost:4000

# ─── API Service ──────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Worker Schedules (cron syntax) ─────────────────────────────────────────
# External trend sync — every 6 hours
TREND_SYNC_CRON=0 */6 * * *

# Tautulli signal sync — every 2 hours
TAUTULLI_SYNC_CRON=0 */2 * * *

# Scoring recalculation — 30 min after every 6 hours
SCORING_CRON=30 */6 * * *

# Jellyseerr request status sync — every hour
JELLYSEERR_STATUS_SYNC_CRON=0 * * * *

# Library availability sync — every 3 hours
LIBRARY_SYNC_CRON=0 */3 * * *

# Lifecycle evaluation — daily at 4:00 AM
LIFECYCLE_EVAL_CRON=0 4 * * *

# Export generation — 15 min after every 6 hours
EXPORT_CRON=15 */6 * * *

# ─── Export ───────────────────────────────────────────────────────────────────
# Absolute path or Docker volume mount where Kometa-ready JSON exports are written.
EXPORT_OUTPUT_DIR=./exports

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
