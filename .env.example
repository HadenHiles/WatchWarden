# ─── Watch Warden — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Integration credentials (Plex, Tautulli, Jellyseerr, TMDB, Trakt) are
# configured through the onboarding wizard and stored in the database.
# You do NOT need to set them here.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_strong_password_here
DATABASE_URL=postgresql://watchwarden:changeme_strong_password_here@localhost:5432/watchwarden

# ─── Admin Credentials ────────────────────────────────────────────────────────
# Default password is "password" — the app will force a change on first login.
# To override before first launch: node -e "const b=require('bcryptjs');console.log(b.hashSync('yourpassword',12))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$12$k.s9xneegzdTGzbkhsQQqeQUISf8KqCfuIM6axc3zDwKR71Mvgwn.

# ─── Session / Auth ───────────────────────────────────────────────────────────
# Minimum 32 characters.
SESSION_SECRET=replace_me_with_a_32_char_secret_value
API_SECRET=replace_me_with_a_different_api_secret
NEXTAUTH_SECRET=replace_me_with_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# ─── Web App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Watch Warden
# URL the Next.js server uses to reach the API (internal Docker network — never exposed to browser)
API_URL=http://localhost:4000

# ─── API Service ──────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Worker Schedules (cron syntax) ──────────────────────────────────────────
# All schedules have sensible defaults; only set these to override.

# External trend sync — every 6 hours
TREND_SYNC_CRON=0 */6 * * *

# Tautulli signal sync — every 2 hours
TAUTULLI_SYNC_CRON=0 */2 * * *

# Scoring recalculation — 30 min after every 6 hours
SCORING_CRON=30 */6 * * *

# Jellyseerr request status sync — every hour
JELLYSEERR_STATUS_SYNC_CRON=0 * * * *

# Jellyseerr-based library availability sync — every 3 hours
LIBRARY_SYNC_CRON=0 */3 * * *

# Lifecycle evaluation — daily at 4:00 AM
LIFECYCLE_EVAL_CRON=0 4 * * *

# Export generation — 15 min after every 6 hours
EXPORT_CRON=15 */6 * * *

# Plex library scan (updates inLibrary + plexRatingKey) — every 4 hours
PLEX_LIBRARY_SYNC_CRON=0 */4 * * *

# Plex collection sync — 45 min after every 6 hours
PLEX_SYNC_CRON=45 */6 * * *

# ─── Export ───────────────────────────────────────────────────────────────────
# Absolute path or Docker volume mount where JSON exports are written.
EXPORT_OUTPUT_DIR=./exports

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
