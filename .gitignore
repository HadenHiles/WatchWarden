# ─── Node.js ──────────────────────────────────────────────
node_modules/
dist/
build/
.cache/
coverage/

# ─── Next.js ──────────────────────────────────────────────
.next/
out/

# ─── Environment ──────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Logs ─────────────────────────────────────────────────
*.log
logs/

