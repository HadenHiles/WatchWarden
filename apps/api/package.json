{
    "name": "@watchwarden/api",
    "version": "1.0.0",
    "private": true,
    "description": "Watch Warden — REST API service",
    "main": "./dist/index.js",
    "scripts": {
        "build": "tsc",
        "dev": "nodemon --watch src --ext ts --exec ts-node -r tsconfig-paths/register src/index.ts",
        "start": "node dist/index.js",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src --ext .ts"
    },
    "dependencies": {
        "@watchwarden/config": "workspace:*",
        "@watchwarden/db": "workspace:*",
        "@watchwarden/integrations": "workspace:*",
        "@watchwarden/scoring": "workspace:*",
        "@watchwarden/types": "workspace:*",
        "bcryptjs": "^2.4.3",
        "connect-pg-simple": "^9.0.1",
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "express-session": "^1.17.3",
        "helmet": "^7.1.0",
        "morgan": "^1.10.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/connect-pg-simple": "^7.0.3",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/express-session": "^1.17.10",
        "@types/morgan": "^1.9.9",
        "@types/node": "^20.11.5",
        "nodemon": "^3.0.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.3.3"
    }
}