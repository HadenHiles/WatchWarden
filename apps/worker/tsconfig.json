{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "./dist",
        "baseUrl": ".",
        "paths": {
            "@watchwarden/config": [
                "../../packages/config/dist"
            ],
            "@watchwarden/db": [
                "../../packages/db/dist"
            ],
            "@watchwarden/integrations": [
                "../../packages/integrations/dist"
            ],
            "@watchwarden/scoring": [
                "../../packages/scoring/dist"
            ],
            "@watchwarden/types": [
                "../../packages/types/dist"
            ]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}