{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "composite": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "baseUrl": ".",
        "paths": {
            "@watchwarden/config": ["../config/dist"],
            "@watchwarden/config/*": ["../config/dist/*"],
            "@watchwarden/types": ["../types/dist"],
            "@watchwarden/types/*": ["../types/dist/*"],
            "@watchwarden/db": ["../db/dist"],
            "@watchwarden/db/*": ["../db/dist/*"]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
