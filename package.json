{
    "name": "watchwarden",
    "private": true,
    "version": "1.0.0",
    "description": "Watch Warden — self-hosted media curation and lifecycle management for home Plex servers",
    "packageManager": "pnpm@8.15.1",
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=8.0.0"
    },
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev --parallel",
        "lint": "turbo run lint",
        "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
        "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
        "test": "turbo run test",
        "test:watch": "turbo run test:watch",
        "typecheck": "turbo run typecheck",
        "db:generate": "pnpm --filter @watchwarden/db run db:generate",
        "db:migrate": "pnpm --filter @watchwarden/db run db:migrate",
        "db:migrate:deploy": "pnpm --filter @watchwarden/db run db:migrate:deploy",
        "db:seed": "pnpm --filter @watchwarden/db run db:seed",
        "db:studio": "pnpm --filter @watchwarden/db run db:studio",
        "db:reset": "pnpm --filter @watchwarden/db run db:reset",
        "clean": "turbo run clean && rm -rf node_modules"
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^6.18.1",
        "@typescript-eslint/parser": "^6.18.1",
        "dotenv-cli": "^11.0.0",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-import": "^2.29.1",
        "prettier": "^3.2.4",
        "turbo": "^1.12.4",
        "typescript": "^5.3.3"
    }
}